# Server
PORT=5000
NODE_ENV=development

# Database
MONGO_URI=mongodb://localhost:27017/mayleki

# JWT
JWT_SECRET=mayleki_super_secret_jwt_key_2025_change_in_production
JWT_EXPIRES_IN=7d

# Client URL
CLIENT_URL=http://localhost:5173

# Cloudinary (get from cloudinary.com)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Razorpay (get from razorpay.com - test keys for development)
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_key_secret

# Email (if using nodemailer)
EMAIL_USER=hello@mayleki.com
EMAIL_PASS=your_email_password
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587

# SMS/OTP (MSG91 or Twilio)
MSG91_AUTH_KEY=your_msg91_key
MSG91_SENDER_ID=MAYLKI

# App
BUSINESS_NAME=Mayleki Imitation Jewellery
BUSINESS_PHONE=+919876543210
BUSINESS_EMAIL=hello@mayleki.com
